# Bu dosyayı "keystore.properties" olarak kopyalayıp gerçek değerlerle doldurun.
# keystore.properties .gitignore'dadır — asla sürüm kontrolüne eklenmez.
#
# Keystore oluşturmak için:
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# storeFile göreli yol veriyorsanız android/ dizinine göre olmalıdır.
storeFile=upload-keystore.jks
storePassword=
keyAlias=upload
keyPassword=
